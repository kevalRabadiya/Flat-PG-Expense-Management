# Local API (empty = Vite dev proxy to backend)
VITE_API_URL=

# Vercel: add under Project → Settings → Environment Variables for Production
# (and Preview if you use preview URLs), then redeploy — Vite bakes this in at build time.
# Use your exact Render hostname (https, no trailing slash).
# VITE_API_URL=https://flat-pg-expense-management-1.onrender.com
#
# Optional emergency override without rebuild: in index.html add a normal (non-module)
# <script> block BEFORE <script type="module" src="/src/main.jsx">:
#   window.__TIFIN_API_BASE__ = "https://your-api.onrender.com";

VITE_HOUSEKEEPER_RATE_PER_DAY=
